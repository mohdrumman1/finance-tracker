{
  "name": "finance-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "postbuild": "node -e \"const fs=require('fs'),path=require('path'),base='/vercel/output/functions';const rm=(d)=>{if(!fs.existsSync(d))return;for(const f of fs.readdirSync(d)){const p=path.join(d,f);if(f==='.vc-config.json')fs.unlinkSync(p);else if(fs.statSync(p).isDirectory())rm(p)}};rm(base);\"",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/adapter-libsql": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.39",
    "@types/papaparse": "^5.5.2",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
